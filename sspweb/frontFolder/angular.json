{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "meb_frontend": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": false
        },
        "@schematics/angular:directive": {
          "standalone": false
        },
        "@schematics/angular:pipe": {
          "standalone": false
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "node_modules/@oblique/oblique/assets",
                "output": "assets"
              },
              {
                "glob": "*/**",
                "input": "node_modules/@oblique/oblique/styles/fonts",
                "output": "assets/fonts"
              },
              "src/assets"
            ],
            "styles": [
              "node_modules/@oblique/oblique/styles/css/oblique-core.css",
              "src/styles/styles.scss"
            ],
            "allowedCommonJsDependencies": [
              "ajv",
              "ajv-formats"
            ],
            "main": "src/main.ts",
            "outputPath": "dist",
            "baseHref": "./",
            "deployUrl": "/sspweb/frontFolder/",
            "index": "src/index.html"
          },
          "configurations": {
            "development": {
              "buildOptimizer": false,
              "vendorChunk": true,
              "optimization": false,
              "sourceMap": true,
              "outputHashing": "none"
            },

            "dev": {
              "optimization": false,
              "buildOptimizer": false,
              "vendorChunk": true,
              "sourceMap": true,
              "outputHashing": "none",
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5mb",
                  "maximumError": "11mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "25kb",
                  "maximumError": "65kb"
                }
              ]
            },

            "local": {
              "optimization": false,
              "buildOptimizer": false,
              "vendorChunk": true,
              "sourceMap": true,
              "outputHashing": "none",
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5mb",
                  "maximumError": "11mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "25kb",
                  "maximumError": "65kb"
                }
              ]
            },

            "ref": {
              "optimization": false,
              "buildOptimizer": false,
              "vendorChunk": true,
              "sourceMap": false,
              "outputHashing": "none",
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5mb",
                  "maximumError": "11mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "25kb",
                  "maximumError": "65kb"
                }
              ]
            },

            "abn": {
              "optimization": false,
              "buildOptimizer": false,
              "vendorChunk": true,
              "sourceMap": false,
              "outputHashing": "none",
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5mb",
                  "maximumError": "11mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "25kb",
                  "maximumError": "65kb"
                }
              ]
            },

            "test": {
              "optimization": false,
              "buildOptimizer": false,
              "vendorChunk": true,
              "sourceMap": true,
              "outputHashing": "none",
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "5mb",
                  "maximumError": "11mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "25kb",
                  "maximumError": "65kb"
                }
              ]
            },

            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "3mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "12kb",
                  "maximumError": "15kb"
                }
              ],
              "optimization": true,
              "buildOptimizer": true,
              "outputHashing": "all",
              "sourceMap": false,
              "vendorChunk": false
            },

            "prod": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "3mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "12kb",
                  "maximumError": "15kb"
                }
              ],
              "optimization": true,
              "buildOptimizer": true,
              "outputHashing": "all",
              "sourceMap": false,
              "vendorChunk": false
            }
          },

          "defaultConfiguration": "dev"
        },

        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "meb_frontend:build:production"
            },
            "development": {
              "buildTarget": "meb_frontend:build:development"
            },
            "dev": {
              "buildTarget": "meb_frontend:build:dev"
            },
            "local": {
              "buildTarget": "meb_frontend:build:local"
            }
          },
          "defaultConfiguration": "development"
        },

        "test": {
          "builder": "@angular-builders/jest:run",
          "options": {
            "configPath": "tests/jest.config.js",
            "tsConfig": "tsconfig.spec.json",
            "max-workers": [
              "2"
            ]
          }
        },

        "lint": {
          "builder": "@angular-eslint/builder:lint",
          "options": {
            "lintFilePatterns": [
              "src/**/*.ts",
              "src/**/*.html"
            ]
          }
        }
      }
    }
  },

  "schematics": {
    "@schematics/angular:component": {
      "prefix": "app",
      "style": "scss"
    },
    "@schematics/angular:directive": {
      "prefix": "app"
    }
  },

  "cli": {
    "analytics": false
  }
}
