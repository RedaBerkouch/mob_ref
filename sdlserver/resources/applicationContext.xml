		<property name="deliveryRepository" ref="deliveryRepository"/>
		<property name="schoolRepository" ref="schoolRepository"/>
		<property name="schoolService" ref="schoolServiceImpl"/>
		<property name="classService" ref="classServiceImpl"/>
		<property name="learnerService" ref="learnerServiceImpl"/>
