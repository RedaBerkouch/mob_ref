		<property name="interventionRepository" ref="interventionRepository"/>
		<property name="cantonRepository" ref="cantonRepository"/>
		<property name="configDeliveryRepository" ref="configDeliveryRepository"/>
		<property name="filterUtility" ref="filterUtility" />
		<property name="deliveryService" ref="deliveryServiceImpl"/>
		<property name="transactionManager" ref="transactionManager"/>
		<property name="headReader" ref="headItemReader"/>
		<property name="csvHeadReader" ref="csvHeadReader"/>
		<property name="localizationManager" ref="localizationManager"/>
	</bean>
	
	<bean class="ch.bfs.meb.server.commons.service.impl.UploadServiceImpl" id="uploadServiceImpl">
		<property name="uploadServiceProvider">
			<ref bean="uploadServiceProvider"/>
		</property>
	</bean>

	<bean id="headItemReader" class="ch.bfs.meb.sdl.server.business.HeadItemReader">
		<property name="fragmentRootElementName" value="head" />
		<property name="unmarshaller" ref="headUnmarshaller" />
	</bean>

	<oxm:xmlbeans-marshaller id="headUnmarshaller" options="headXmlBeansOptions"/>

	<bean id="headXmlBeansOptions" class="ch.bfs.meb.sdl.server.business.HeadXmlBeansOptions"/>

	<bean id="csvHeadReader" class="org.springframework.batch.item.file.FlatFileItemReader">
		<property name="lineMapper">
			<bean class="org.springframework.batch.item.file.mapping.DefaultLineMapper">
				<property name="lineTokenizer">
					<bean class="ch.bfs.meb.sdl.server.business.delivery.csv.CsvDelimitedLineTokenizer">
						<property name="names" value="VERSION,CANTONID,DATADELIVERY,DELIVERYDATE,CONFIRMDELIVERY,DUMMY1,DUMMY2,DUMMY3,DUMMY4,DUMMY5,DUMMY6,DUMMY7,DUMMY8,DUMMY9,DUMMY10,DUMMY11,DUMMY12,DUMMY13,DUMMY14,DUMMY15,DUMMY16,DUMMY17,DUMMY18,DUMMY19,DUMMY20,DUMMY21,DUMMY22,DUMMY23,DUMMY24" />
						<property name="delimiter" value=";"/>
					</bean>
				</property>
				<property name="fieldSetMapper">
					<bean class="ch.bfs.meb.sdl.server.business.delivery.csv.CsvHeadFieldSetMapper" />
				</property>
			</bean>
		</property>
	</bean>
	
	<bean class="ch.bfs.meb.sdl.server.service.impl.ConfigDeliveryServiceProvider" id="configDeliveryServiceProvider">
		<property name="configDeliveryRepository" ref="configDeliveryRepository"/>
    	<property name="idmService" ref="${configuration.idm.implementation}"/>
	</bean>
	
	<bean class="ch.bfs.meb.server.commons.service.impl.ConfigDeliveryServiceImpl" id="configDeliveryServiceImpl">
		<property name="configDeliveryServiceProvider" ref="configDeliveryServiceProvider" />
		<property name="filterServiceProvider" ref="filterServiceProvider" />
	</bean>
	
	<bean class="ch.bfs.meb.sdl.server.integration.repository.SecurityFilters" id="securityFilters">
		<property name="codegroupManager" ref="codegroupManager"/>
		<property name="filterRepository" ref="filterRepository" />
    	<property name="idmService" ref="${configuration.idm.implementation}"/>
	</bean>
	
	<bean class="ch.bfs.meb.server.commons.util.FilterUtility" id="filterUtility">
