		</property>
		<property name="deliveryRepository">
			<ref bean="deliveryRepository" />
		</property>
		<property name="burSchoolRepository">
			<ref bean="burSchoolRepository" />
		</property>
		<property name="schoolRepository">
			<ref bean="schoolRepository" />
		</property>
		<property name="classRepository">
