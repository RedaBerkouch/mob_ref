		<property name="burSchoolService" ref="burSchoolServiceImpl"/>
	</bean>

	<bean class="ch.bfs.meb.sdl.server.business.plausi.PlausireportFactory" id="plausireportFactory">
		<property name="plausiErrorRepository" ref="plausierrorRepository"/>
		<property name="codegroupManager" ref="codegroupManager"/>
		<property name="plausiRepository" ref="plausiRepository"/>
		<property name="learnerRepository" ref="learnerRepository"/>
		<property name="localizationManager" ref="localizationManager"/>
	</bean>

