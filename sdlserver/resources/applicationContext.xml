		<property name="plausiErrorRepository" ref="plausierrorRepository"/>
		<property name="plausiRepository" ref="plausiRepository"/>
	</bean>
	
	<bean class="ch.bfs.meb.server.commons.service.impl.ExportServiceImpl" id="exportServiceImpl">
		<property name="exportServiceProvider" ref="exportServiceProvider"/>
		<property name="burSchoolServiceProvider" ref="burSchoolServiceProvider"/>
		<property name="sasService" ref="sasService"/>
		<property name="localizationManager" ref="localizationManager"/>
	</bean>
	
	<bean class="ch.bfs.meb.sdl.server.service.impl.ParameterServiceProvider" id="parameterServiceProvider">
		<property name="parameterRepository">
			<ref bean="parameterRepository" />
		</property>
	</bean>
	
