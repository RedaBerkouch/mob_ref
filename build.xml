			<fileset dir="${meb.wsdl.root.dir}">
				<include name="*.wsdl" />
			</fileset>
			<fileset dir="${meb.wsdl.root.dir}">
				<include name="*.xsd" />
			</fileset>
		</copy>

		<echo>
			Packing MEB application delivery archive...
		</echo>
		<mkdir dir="${delivery.application.dir}" />
		<zip destfile="${delivery.application.dir}/MEB_APP_V${meb.version}.zip">
			<fileset dir="${meb.delivery.version.dir}">
