	<property file="sspweb/resources/version.properties" prefix="ssp" />

	<property file="sbaweb/resources/version.properties" prefix="sba" />

	<property file="build.properties" />

	<tstamp />

	<available file="documentation/ReleaseNotes/README.meb.${meb.version}.txt" property="readmeFileIsAvailable" />
	<fail unless="readmeFileIsAvailable" message="README.meb.${meb.version}.txt does not exist. Please create it and re-try build." />

	<target name="main" depends="database,meb,sbg,sdl,ssp,sba,wsdl,ear,pack">
		<echo>Building delivery packages.</echo>
	</target>

	<target name="database">
		<echo>
			Creating database delivery...
		</echo>
		<delete dir="${database.delivery.version.dir}" />
		<mkdir dir="${database.delivery.version.dir}" />
		<mkdir dir="${mebdb.flyway.delivery.scripts.dir}" />
		<copy todir="${mebdb.flyway.delivery.conf.dir}">
			<fileset dir="${mebdb.flyway.conf.dir}" >
				<include name="flyway.conf" />
			</fileset>
		</copy>
		<copy todir="${mebdb.flyway.delivery.scripts.dir}">
			<fileset dir="${mebdb.flyway.scripts.dir}">
				<include name="**/*.sql" />
			</fileset>
		</copy>

		<echo>
			Creating database delivery zip...
		</echo>
		<zip destfile="${database.delivery.root.dir}/MEB_DB_V${meb.version}.zip">
			<fileset dir="${database.delivery.version.dir}">
				<include name="**" />
			</fileset>
		</zip>

	</target>

	<target name="meb">
		<echo>
			Creating MEB target directories...
		</echo>
		<delete dir="${meb.delivery.version.dir}" />
		<mkdir dir="${meb.delivery.version.dir}" />

		<echo>
			Copying MEB EARs...
		</echo>
		<copy todir="${meb.delivery.version.dir}">
			<fileset dir="${meb.serverEAR.target.dir}">
				<include name="*.ear" />
			</fileset>
			<fileset dir="${meb.webEAR.target.dir}">
				<include name="*.ear" />
			</fileset>
<!--			<globmapper from="*-0.0.1-SNAPSHOT.ear" to="*-${meb.version}.ear" />-->
		</copy>

		<echo>
			Copying MEB README.txt...
		</echo>
		<copy todir="${meb.delivery.version.dir}">
			<fileset dir="${meb.web.root.dir}">
				<include name="README.txt" />
			</fileset>
		</copy>

		<echo>
			Copying MEB wsdls...
